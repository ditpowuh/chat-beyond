{
  "name": "chat-beyond",
  "version": "1.0.0",
  "description": "A web interface to use OpenAI's API, made to be familiar and easy.",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently 'bun run server:dev' 'bun run client:dev'",
    "server:dev": "bun index.ts --tsconfig-override tsconfig.bun.json",
    "server:check": "bun x tsc -p tsconfig.bun.json",
    "build:windows": "bun build index.ts --compile --target=bun-windows-x64 --outfile output/ChatBeyond-windows-x64",
    "build:mac": "bun build index.ts --compile --target=bun-darwin-arm64 --outfile output/ChatBeyond-macos-arm64",
    "client:build": "vite build",
    "client:dev": "vite",
    "node:start": "node dist/index.js",
    "node:compile": "tsc -p tsconfig.node.json"
  },
  "author": "Ditpowuh",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/socket.io": "^3.0.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0"
  },
  "dependencies": {
    "@tsparticles/confetti": "^3.9.1",
    "chalk": "^5.6.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "image-size": "^2.0.2",
    "lenis": "^1.3.19",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "marked-katex-extension": "^5.1.6",
    "open": "^11.0.0",
    "openai": "^6.32.0",
    "pdf-parse": "^1.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "sweetalert2": "^11.26.24",
    "tiktoken": "^1.0.22",
    "uuid": "^13.0.0"
  },
  "engine": {
    "bun": ">=1.3.4"
  }
}
